{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "framework": "nextjs",
      "routePrefix": "/",
      "installCommand": "corepack pnpm install --frozen-lockfile",
      "buildCommand": "corepack pnpm run build"
    },
    "backend": {
      "entrypoint": "backend/src/index.js",
      "builder": "@vercel/node",
      "routePrefix": "/api"
    }
  }
}
